<?xml version="1.0" encoding="UTF-8"?>
<!-- INTERNAL manifest — FAQAT com.frameflow.admin. MIJOZ PAKETIGA HECH QACHON KIRMAYDI.
     Alohida ExtensionBundleId (com.frameflow.internal.admin) → alohida CEP papkasi, shuning
     uchun mijozning com.frameflow o'rnatmasi ustiga hech qachon tushmaydi.
     Flavor manbai: scripts/package-flavors.mjs · hujjat: docs/RELEASE-ARCHITECTURE.md -->
<ExtensionManifest Version="7.0"
  ExtensionBundleId="com.frameflow.internal.admin"
  ExtensionBundleVersion="1.1.1"
  ExtensionBundleName="FrameFlow Admin (Internal)">
  <ExtensionList>
    <Extension Id="com.frameflow.admin" Version="1.1.1"/>
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <Host Name="AEFT" Version="[22.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="11.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.frameflow.admin">
      <DispatchInfo>
        <Resources>
          <MainPath>./AssetFlow_Admin.html</MainPath>
          <ScriptPath>./jsx/host.jsx</ScriptPath>
          <CEFCommandLine>
            <!-- Web-security'ni o'chiruvchi CEF bayrog'i OLIB TASHLANDI (audit 2026-07-21).
                 Admin ham mijoz paneli bilan bir xil birinchi-tomon HTTPS API + CORS
                 kontraktidan foydalanadi; backend CORS/auth ZAIFLASHTIRILMAYDI. -->
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--allow-file-access</Parameter>
            <Parameter>--persist-session-cookies</Parameter>
            <Parameter>--mixed-context</Parameter>
            <Parameter>--enable-nodejs</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>false</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>FrameFlow Admin</Menu>
          <Geometry>
            <Size><Height>760</Height><Width>420</Width></Size>
            <MinSize><Height>500</Height><Width>360</Width></MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
