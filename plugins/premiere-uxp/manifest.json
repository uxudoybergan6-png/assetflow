{
  "id": "com.oceananimatsion.creativetools.premiere",
  "name": "CreativeTools",
  "version": "0.1.0",
  "main": "index.html",
  "manifestVersion": 6,
  "host": [
    {
      "app": "PPRO",
      "minVersion": "24.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "creativetools.panel",
      "label": {
        "default": "CreativeTools"
      },
      "minimumSize": { "width": 320, "height": 400 },
      "maximumSize": { "width": 800, "height": 1200 },
      "preferredDockedSize": { "width": 360, "height": 600 }
    }
  ],
  "requiredPermissions": [
    "network",
    "localFileSystem",
    "clipboard"
  ],
  "icons": [
    {
      "width": 24,
      "height": 24,
      "path": "icons/icon.png",
      "scale": [1, 2]
    }
  ]
}
