{
  "name": "creative-tools-saas",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:studio-web": "npm run dev:studio-web -w @creative-tools/frameflow-studio",
    "dev:api": "npm run dev -w @creative-tools/api",
    "dev:studio-admin": "npm run dev -w @creative-tools/frameflow-studio",
    "studio": "node scripts/start-studio.mjs",
    "api:only": "node scripts/run-api-only.mjs",
    "studio:ui": "node scripts/start-studio-ui.mjs",
    "verify:pipeline": "node scripts/verify-pipeline.mjs",
    "test:plugin-package": "node plugins/after-effects-cep/scripts/test-package-security.mjs",
    "check:stack": "node scripts/check-stack.mjs",
    "studio:open": "open http://localhost:3000/studio/hub.html",
    "build": "npm run build --workspaces --if-present",
    "db:generate": "npm run generate -w @creative-tools/database",
    "db:push": "npm run push -w @creative-tools/database",
    "db:seed": "npm run seed -w @creative-tools/database",
    "db:seed:assetflow": "npm run seed:assetflow -w @creative-tools/database",
    "studio:sync": "npm run sync:web -w @creative-tools/frameflow-studio",
    "demo:clear": "node scripts/clear-assetflow-demo.mjs",
    "reconcile:plans": "node scripts/reconcile-plugin-plans.mjs",
    "perf:seed": "node scripts/perf-seed-assets.mjs",
    "perf:measure": "node scripts/perf-measure.mjs",
    "db:backup": "node scripts/db-backup.mjs",
    "backfill:embedvec": "node scripts/backfill-embedding-vec.mjs",
    "backfill:free-credits": "node scripts/backfill-free-credits.mjs",
    "retranscode:previews": "node scripts/retranscode-previews.mjs",
    "pm2:start": "node scripts/pm2-start.mjs",
    "pm2:stop": "node scripts/pm2-stop.mjs",
    "pm2:reset": "node scripts/pm2-reset.mjs",
    "pm2:restart": "npm run pm2:stop && npm run pm2:start",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "pm2": "^7.0.3"
  }
}
