# Database
# macOS Homebrew: odatda foydalanuvchi = tizim nomi (postgres emas)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/creative_tools?schema=public"
DATABASE_URL="postgresql://YOUR_MAC_USERNAME@localhost:5432/creative_tools?schema=public"

# API
API_PORT=4000
JWT_SECRET="change-me-in-production"
CORS_ORIGIN="http://localhost:3000"
WEB_URL="http://localhost:3000"

# Stripe (Oceananimatsion Ltd UK account)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_MONTHLY="price_..."
STRIPE_PRICE_YEARLY="price_..."

# AWS S3 + Cloudflare CDN
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="creative-tools-assets"
CDN_BASE_URL="https://cdn.yourdomain.com"

# Cloudflare Workers AI (AI Tools — rasm/ovoz/qidiruv)
# Kalitlar bo'lmasa AI route'lar 503 AI_NOT_CONFIGURED qaytaradi.
CF_ACCOUNT_ID=""
CF_AI_TOKEN=""
AI_MODEL_IMAGE="@cf/black-forest-labs/flux-1-schnell"
AI_MODEL_EMBED="@cf/baai/bge-m3"
AI_MODEL_TEXT="@cf/meta/llama-3.1-8b-instruct"
AI_MODEL_TTS="@cf/myshell-ai/melotts"
