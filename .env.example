# Database
# macOS Homebrew: odatda foydalanuvchi = tizim nomi (postgres emas)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/creative_tools?schema=public"
DATABASE_URL="postgresql://YOUR_MAC_USERNAME@localhost:5432/creative_tools?schema=public"
# Miqyos (ixtiyoriy) — Neon pgbouncer / Cloud Run pooling. Bo'sh = o'zgarishsiz.
# Batafsil: docs/DR-RUNBOOK.md → "6. Connection pooling".
# DATABASE_CONNECTION_LIMIT=5   # Prisma per-instans pool hajmi (URL'ga qo'shiladi)

# API
API_PORT=4000
JWT_SECRET="change-me-in-production"
CORS_ORIGIN="http://localhost:3000"
WEB_URL="http://localhost:3000"
# Rate-limit backend (ixtiyoriy) — o'rnatilsa limiter Redis'da ishlaydi (ko'p instans
# uchun umumiy limit). Bo'sh = in-memory (bugungi holat). ioredis kerak: npm i ioredis -w apps/api
# REDIS_URL="redis://localhost:6379"

# Stripe (Oceananimatsion Ltd UK account)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_MONTHLY="price_..."
STRIPE_PRICE_YEARLY="price_..."

# AWS S3 + Cloudflare CDN
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="creative-tools-assets"
CDN_BASE_URL="https://cdn.yourdomain.com"

# OpenRouter (Studio Gen — rasm/video/ovoz/embeddings, yagona unified API)
# Kalit bo'lmasa /studio/gen route'lari 503 AI_NOT_CONFIGURED qaytaradi.
OPENROUTER_API_KEY=""

# Cloudflare Workers AI (eski AI Tools /plugin/ai — rasm/ovoz/qidiruv; Studio Gen OpenRouter'da)
# Kalitlar bo'lmasa shu route'lar 503 AI_NOT_CONFIGURED qaytaradi.
CF_ACCOUNT_ID=""
CF_AI_TOKEN=""
AI_MODEL_IMAGE="@cf/black-forest-labs/flux-1-schnell"
AI_MODEL_EMBED="@cf/baai/bge-m3"
AI_MODEL_TEXT="@cf/meta/llama-3.1-8b-instruct"
AI_MODEL_TTS="@cf/myshell-ai/melotts"
