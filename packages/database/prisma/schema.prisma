generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Runtime client — Neon POOLED endpoint (-pooler, pgbouncer=true) ishlatilsin (P8 #2).
  url      = env("DATABASE_URL")
  // Migratsiya/introspeksiya — DIRECT (poolsiz) endpoint. pgbouncer migratsiya DDL'ni
  // qo'llab-quvvatlamaydi, shuning uchun migrate:deploy shu URL'dan foydalanadi.
  // DIRECT_DATABASE_URL o'rnatilmagan bo'lsa CI uni DATABASE_URL'ga tenglashtiradi (fallback).
  directUrl = env("DIRECT_DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  CONTRIBUTOR
}

enum TemplateReviewStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
}

enum AssetType {
  MOTION_TEMPLATE
  TRANSITION
  VFX_OVERLAY
  TEXTURE
  LUT
  PRESET
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  passwordHash     String?
  role                 UserRole  @default(USER)
  contributorBlockedAt DateTime?
  // FAZA 6b — contributor onboarding: USER "Become a contributor" so'rovi.
  // Admin rol berganda (yoki rad etganda) null'ga qaytadi.
  contributorRequestedAt DateTime?
  tokenVersion         Int       @default(0)
  // ADMIN 2FA (TOTP) — faqat ADMIN hisoblari uchun ishlatiladi.
  // totpSecret AES-256-GCM shifrlangan (apps/api lib/twofa.ts), totpBackupCodes
  // sha256-hash'langan bir martalik tiklash kodlari (ishlatilganda o'chiriladi).
  totpSecret           String?
  totpEnabled          Boolean   @default(false)
  totpBackupCodes      String[]  @default([])
  stripeCustomerId     String?   @unique
  // FAZA 1c — GDPR self-serve o'chirish: belgilangan bo'lsa hisob anonimlashtirilgan
  // (PII tozalangan, tokenlar bekor qilingan). Moliyaviy yozuvlar (earning/payout) saqlanadi.
  deletedAt        DateTime?
  emailVerified    DateTime?
  image            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  subscription  Subscription?
  downloads     Download[]
  pluginTokens          PluginToken[]
  pluginProfile         PluginProfile?
  contributorTemplates  ContributorTemplate[] @relation("ContributorTemplates")
  reviewedTemplates     ContributorTemplate[] @relation("ReviewedTemplates")
  studioThreads         StudioMessageThread[] @relation("ContributorThreads")
  studioMessagesSent    StudioMessage[]       @relation("StudioMessagesSent")
  studioAuditLogs       StudioAuditLog[]      @relation("StudioAuditActor")
  aiGenerations         AiGeneration[]
  genSessions           GenSession[]
  generations           Generation[]
  savedReferences       SavedReference[]
  projects              Project[]

  @@index([role])
}

enum PluginPlanTier {
  FREE
  PRO
  STUDIO
}

enum PluginAccountStatus {
  ACTIVE
  BLOCKED
  REMOVED
}

model PluginProfile {
  userId         String               @id
  plan           PluginPlanTier       @default(FREE)
  status         PluginAccountStatus  @default(ACTIVE)
  downloadsTotal Int                  @default(0)
  downloadsMonth Int                  @default(0)
  importsTotal   Int                  @default(0)
  importsMonth   Int                  @default(0)  // P21: import limiti endi OYLIK (downloadsMonth kabi monthResetAt'da reset). importsTotal umrlik STATISTIKA uchun qoladi.
  monthResetAt   DateTime             @default(now())
  aiCredits      Int                  @default(50)
  aiCreditsTopup Int                  @default(0)  // Bosqich 4 #5: aiCredits ichidagi sotib olingan TOP-UP ulushi (oylik reset'da SAQLANADI). Invariant: 0 <= aiCreditsTopup <= aiCredits.
  aiCreditsResetAt DateTime           @default(now())
  lastSeenAt     DateTime?
  deviceLabel    String?
  aeVersion      String?
  downloadLimitOverride Int?
  importLimitOverride   Int?
  // FAZA 4 (B) — dunning/risk holati (additive): "payment_failed" | "past_due" |
  // "unpaid" | "chargeback". null = sog'lom. Faqat KO'RSATKICH — kirish gate'lari
  // (plan/status) mavjud oqimlarda hal bo'ladi, bu ustun hech narsani bloklamaydi.
  billingIssue   String?
  billingIssueAt DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([plan])
  @@index([lastSeenAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Stripe webhook idempotency — har event.id bir marta ishlanadi
/// (takror/parallel yetkazishni dedup qiladi).
model WebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

/// DEPRECATED (Bosqich 4 #2) — jonli katalog EMAS. Marketplace'ning yagona haqiqat
/// manbai `ContributorTemplate`. `Asset` faqat eski demo seed'da yaratiladi (dev),
/// hech qanday jonli route uni o'qimaydi. Model migratsiya-xavfsizligi uchun saqlanadi
/// (o'chirish = destructive migratsiya). Yangi kod ContributorTemplate'ni ishlatsin.
model Asset {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String?
  type        AssetType
  category    String
  tags        String[]
  fileKey     String
  thumbnailKey String?
  fileSize    Int
  duration    Float?
  width       Int?
  height      Int?
  published   Boolean   @default(false)
  downloadCount Int     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  downloads Download[]

  @@index([type, category])
  @@index([published])
}

/// DEPRECATED (Bosqich 4 #2) — hech qachon yaratilmagan o'lik model (`Asset`'ga
/// bog'langan). Real yuklab olish tracking'i endi `TemplateDownloadEvent` (Bosqich 4 #1).
/// Migratsiya-xavfsizligi uchun saqlanadi (o'chirish = destructive). Yangi kod
/// TemplateDownloadEvent'ni ishlatsin.
model Download {
  id        String   @id @default(cuid())
  userId    String
  assetId   String
  source    String   @default("web")
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assetId])
}

model PluginToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model PluginDeviceCode {
  id          String   @id @default(cuid())
  code        String   @unique
  userId      String?
  status      String   @default("pending") // pending | confirmed | denied
  pluginToken String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([expiresAt])
}

model ContributorPlatformSettings {
  id                      String   @id @default("platform")
  apiBaseUrl              String?
  requireApproval         Boolean  @default(true)
  defaultNav              String   @default("video")
  defaultRes              String   @default("4k")
  defaultOrient           String   @default("horizontal")
  categoriesJson          Json     @default("[]")
  contributorInstructions String?  @db.Text
  updatedAt               DateTime @updatedAt
}

model ContributorTemplate {
  id            String               @id @default(cuid())
  contributorId String
  externalId    String?
  name          String
  description   String               @default("")
  nav           String               @default("video")
  cat           String
  catLabel      String
  orient        String               @default("horizontal")
  res           String               @default("4k")
  tags          String[]
  icon          String               @default("✦")
  bg            String               @default("")
  templateApp   String               @default("ae")
  // ── Stock kengayishi S1 (STOCK-EXPANSION-PLAN.md) — ADDITIVE ──
  // kind: 'template' | 'stock'. stockType faqat kind='stock' uchun ('video'|'music'|'sfx'|'photo').
  // templateType — 4 keng tur (web pill'lari): 'video-templates'|'motion-graphics'|'graphics'|'luts'.
  kind          String               @default("template")
  stockType     String?
  templateType  String               @default("video-templates")
  // ── P1 (step 30) — ko'p orientatsiya + ffprobe spec (ADDITIVE, hammasi nullable) ──
  // orientations: "vertical and horizontal" → ["horizontal","vertical"]; `orient` esa
  // asosiy qiymatni saqlaydi (katalog/plagin filtri buzilmasin). Bo'sh = bitta orient.
  orientations  String[]             @default([])
  // ffprobe'dan (fayl-o'zidan, hech qachon taxmin emas). Eski qatorlar NULL → UI qatorni
  // ko'rsatmaydi. Looped = algoritmik taxmin (birinchi/oxirgi kadr); xato bo'lsa null (P1.10).
  durationSec   Float?               // video/audio davomiyligi (soniya)
  width         Int?                 // piksel kengligi (video/rasm)
  height        Int?                 // piksel balandligi (video/rasm)
  fps           Float?               // kadr tezligi (video)
  hasAlpha      Boolean?             // alfa kanal (yuva420p/rgba/argb/ProRes 4444) — .mov/.webm
  looped        Boolean?             // seamless loop taxmini (heuristic; null = aniqlanmadi)
  videoCodec    String?              // h264 | hevc | prores | ...
  audioCodec    String?              // mp3 | aac | pcm_s16le | ...
  audioBitrate  Int?                 // audio bitrate (bps)
  sampleRate    Int?                 // audio sample rate (Hz)
  metaJson      Json                 @default("{}")
  fileName      String?
  fileSize      Int?
  reviewStatus  TemplateReviewStatus @default(DRAFT)
  reviewNote    String?
  reviewedById  String?
  reviewedAt    DateTime?
  published     Boolean              @default(false)
  isPro         Boolean              @default(false) // Per-shablon tier: true=PRO-only, false=FREE. Admin belgilaydi. Additive — default false = mavjud shablonlar FREE.
  downloadsCount Int                 @default(0)
  importsCount   Int                 @default(0)
  embedding     Json?                // Semantik qidiruv uchun embedding vektori (bge-m3, JSON float[]) — SAQLANADI (backward-compat + fallback)
  embeddingVec  Unsupported("vector(1024)")? // pgvector (bge-m3 = 1024-dim). Prisma native qo'llamaydi → faqat raw SQL bilan o'qiladi/yoziladi.
  previewTranscodeStatus String?      // #15: fon transcode holati — 'pending' | 'done' | 'failed' (null = hech ishlanmagan)
  previewTranscodeError  String?      // #15: fon transcode xatosi (qisqartirilgan, faqat 'failed' holatda)
  // ── Upload xavfsizligi (Bosqich 2 #2) — ADDITIVE ──
  packHash       String?             // Pack sha256 (hex) — dedup / anti-theft. null = hali hisoblanmagan.
  packScanStatus String?             // Malware+dedup holati: pending|clean|malicious|unknown|quarantined|duplicate. null = eski/skan qilinmagan.
  packScanDetail String?             // Skan tafsiloti (VirusTotal/dedup izohi, admin ko'rishi uchun).
  // ── DMCA / takedown (Bosqich 2 #2) — ADDITIVE ──
  takedownAt     DateTime?           // Belgilangan bo'lsa — katalogdan/serve'dan olib tashlangan (huquqiy da'vo).
  takedownReason String?             // Takedown sababi (DMCA da'vosi va h.k.).
  takedownById   String?             // Kim belgiladi (admin userId).
  // ── Contributor rights attestation (FAZA 1b) — ADDITIVE ──
  // Yuklovchi "bu kontent menga tegishli / tarqatishga haqim bor" tasdig'ini bergan payt +
  // qaysi shart versiyasida. null = eski shablon (attestatsiyadan oldingi). Frontend har
  // upload yo'lida MAJBURIY checkbox bilan bloklaydi; backend shu yerda QAYD etadi.
  rightsAcceptedAt   DateTime?
  rightsTermsVersion String?
  // ── FAZA 5 (A2) — S3 asset kalitlari keshi (ADDITIVE) ──
  // templates/{id}/ prefiksidagi BARCHA obyekt kalitlari (JSON string[]). Har asset
  // mutatsiyasidan keyin syncTemplateAssetKeys yozadi (raw SQL — updatedAt'ga TEGMAYDI).
  // null = hali sinxronlanmagan → listing bir marta live List bilan o'zini to'ldiradi.
  // Katalog/admin listing shu ustundan hasPack/hasPreview/thumb URL'larni oladi —
  // har shablon uchun S3 chaqiruv YO'Q (N+1 fix).
  assetKeysJson  Json?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  contributor User  @relation("ContributorTemplates", fields: [contributorId], references: [id], onDelete: Cascade)
  reviewer    User? @relation("ReviewedTemplates", fields: [reviewedById], references: [id])
  messageThreads StudioMessageThread[]

  @@unique([contributorId, externalId])
  @@index([contributorId])
  @@index([reviewStatus])
  @@index([published])
  @@index([reviewStatus, published, updatedAt])
  @@index([packHash])
  @@index([takedownAt])
  // ── Katalog filtri indekslari (P7 #4 / P6 #6) — ADDITIVE ──
  // Server-side filter (step 15) yozilishidan OLDIN kerak: bularsiz har filtrlangan
  // so'rov ketma-ket skan bo'ladi. Prefiks (published, reviewStatus) barcha katalog
  // so'rovlarida bir xil; keyin pill o'lchovlari, oxirida updatedAt (kursor tartibi).
  @@index([published, reviewStatus, kind, templateType, updatedAt], map: "ct_pub_rev_kind_type_upd_idx")
  @@index([published, reviewStatus, stockType, updatedAt], map: "ct_pub_rev_stock_upd_idx")
  @@index([published, reviewStatus, templateApp, updatedAt], map: "ct_pub_rev_app_upd_idx")
}

model StudioMessageThread {
  id            String   @id @default(cuid())
  contributorId String
  templateId    String?
  subject       String
  isBroadcast   Boolean  @default(false)
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contributor User                 @relation("ContributorThreads", fields: [contributorId], references: [id], onDelete: Cascade)
  template    ContributorTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  messages    StudioMessage[]

  @@index([contributorId])
  @@index([lastMessageAt])
  @@index([templateId])
}

model StudioMessage {
  id        String    @id @default(cuid())
  threadId  String
  senderId  String
  body      String    @db.Text
  readAt    DateTime?
  createdAt DateTime  @default(now())

  thread StudioMessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User                @relation("StudioMessagesSent", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([senderId])
}

model StudioAuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  detail     String?  @db.Text
  metaJson   Json     @default("{}")
  createdAt  DateTime @default(now())

  actor User? @relation("StudioAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([createdAt])
  @@index([actorId])
}

enum AiGenerationType {
  IMAGE
  VOICEOVER
  SFX
  SEARCH
}

enum AiGenerationStatus {
  PENDING
  DONE
  FAILED
}

model AiGeneration {
  id        String             @id @default(cuid())
  userId    String
  type      AiGenerationType
  prompt    String             @db.Text
  resultKey String?
  credits   Int                @default(0)
  status    AiGenerationStatus @default(PENDING)
  createdAt DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ── Studio Gen (Artlist uslubi) — session = ish maydoni ─────────────────────
// AiGeneration (yuqorida) eski sinxron AI Tools oqimi uchun qoladi; yangi generativ
// studio oqimi GenSession/Generation/GenAsset bilan ishlaydi (job + tarix + signed quote).

model GenSession {
  id          String       @id @default(cuid())
  userId      String
  title       String?
  mode        String       @default("image") // image | voice | video | music
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  generations Generation[]

  @@index([userId])
  @@index([createdAt])
}

model Generation {
  id        String     @id @default(cuid()) // jobId sifatida ishlatiladi
  sessionId String
  userId    String                          // kredit/egalik va tezkor so'rov uchun
  mode      String                          // image | voice | video | music
  prompt    String     @db.Text
  modelId   Int                             // model katalog ID (Artlist uslubi → Workers AI key'ga map)
  params    Json       @default("{}")       // duration/aspectRatio/referenceKey...
  status    String     @default("queued")   // queued | running | done | failed
  category  String?
  cost      Int        @default(0)
  refunded  Boolean    @default(false)       // idempotent refund guard — bir job IKKI marta refund qilinmasin (additive, default false)
  // Idempotentlik (P18) — klient job yaratish urinishi uchun bitta UUID yuboradi. Javob
  // yo'qolib klient POST /gen'ni QAYTA yuborsa, server shu kalit bo'yicha MAVJUD job'ni
  // qaytaradi (yangi job yaratmaydi, kredit IKKINCHI marta yechilmaydi). null = eski/kalit-siz
  // so'rov (bir nechta NULL — Postgres unique NULL'ni distinct sanaydi). Additive, money-zone TEGMAYDI.
  idempotencyKey String?
  error     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  session   GenSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets    GenAsset[]
  savedReferences SavedReference[]

  @@unique([userId, idempotencyKey])
  @@index([sessionId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model SavedReference {
  id           String      @id @default(cuid())
  userId       String
  generationId String?
  kind         String
  url          String      @db.Text
  resultKey    String?
  thumbUrl     String?
  contentType  String?
  sizeBytes    Int?
  createdAt    DateTime    @default(now())
  lastUsedAt   DateTime?
  expiresAt    DateTime

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation Generation? @relation(fields: [generationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, expiresAt])
  @@index([generationId])
}

// ── QA-FIX #13 — Projects: gen + shablonlarni loyihaga yig'ish (ADDITIVE) ────
// ProjectItem.refId polimorf (kind bo'yicha Generation.id yoki
// ContributorTemplate.id) — FK yo'q, o'chirilgan manba read paytida filtrlanadi.

model Project {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items ProjectItem[]

  @@index([ownerId, updatedAt])
}

model ProjectItem {
  id        String   @id @default(cuid())
  projectId String
  kind      String // 'gen' | 'template'
  refId     String
  addedAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, kind, refId]) // bir element bir loyihaga bir marta (idempotent add)
  @@index([projectId, addedAt])
}

model GenAsset {
  id           String     @id @default(cuid())
  generationId String
  type         Int                          // 140=video kabi tur kodi (Artlist uslubi)
  url          String                       // R2/CDN URL (signed yoki public)
  resultKey    String?                      // R2 obyekt kaliti (signed URL qayta yaratish uchun)
  thumbUrl     String?
  thumbKey     String?                      // FAZA 2 #8: video poster (birinchi kadr JPG) obyekt kaliti; null = poster yo'q
  displayKey   String?                      // P9: 1280px WebP display derivativ kaliti (Retina karta + alfa); null = eski/yo'q
  previewKey   String?                      // P9.2: 720p video hover-preview kaliti (asl saqlanadi); null = eski/yo'q
  watermarkKey String?                      // P4 (14b): FREE reja yuklab olish/import uchun SUV BELGILI nusxa kaliti (`<base>-wm.<ext>`, private); null = eski/yo'q. Pullik reja TOZA asl'ni oladi (bu kalit ishlatilmaydi).
  width        Int?
  height       Int?
  aspectRatio  String?                      // "16:9"
  sizeBytes    Int?                         // Bosqich 4 #4: storage kvota hisobi (persist'da buf.length). null = eski/noma'lum.
  createdAt    DateTime   @default(now())

  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@index([generationId])
}

// ── Moliyaviy audit izi (Faza 2) — ADDITIVE, mavjud kredit oqimiga aloqasiz ──
// CreditLedger: har kredit consume/refund uchun bitta yozuv (kim, qancha, qaysi gen).
// FK-siz (userId/generationId oddiy indeksli ustun) — User/Generation modeliga tegmaymiz.
model CreditLedger {
  id           String   @id @default(cuid())
  userId       String
  generationId String?
  delta        Int      // manfiy = consume, musbat = refund
  reason       String   // "consume" | "refund"
  balanceAfter Int?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([generationId])
  @@index([createdAt])
}

// ProviderSpend: har gen provayderga yuborilganda bitta yozuv (provayder narx tahlili uchun).
model ProviderSpend {
  id               String   @id @default(cuid())
  generationId     String?
  provider         String   // "vertex" | "vertex-omni" | "vertex-image" | "fal" | "elevenlabs" | "openrouter"
  modelId          Int?
  mode             String?
  credits          Int?
  estimatedCostUsd Decimal? @db.Decimal(10, 4)
  // P24 — real (o'lchangan) provider USD. BytePlus token count (Tier 2) yoki invoice (Tier 1)
  // dan yoziladi. null = faqat estimate. confidence: "measured" | "estimated" | "official".
  // ANALITIKA — kredit matematikasiga TEGMAYDI (money zone emas).
  measuredCostUsd  Decimal? @db.Decimal(10, 4)
  confidence       String?
  createdAt        DateTime @default(now())

  @@index([generationId])
  @@index([provider])
  @@index([createdAt])
}

// ── Bosqich 3.4 — NARX DVIGATELI (admin-managed pricing, DB-backed) ──────────
// ModelPricing: HAR gen model uchun BITTA qator — kredit narx ta'rifi (gen-models.ts
// STATIK katalog o'rniga endi HAQIQAT MANBAI). Seed startup'da gen-models.ts joriy
// qiymatlaridan idempotent create-only upsert bilan to'ldiriladi → narx BUGUNGI bilan
// AYNAN bir xil. Qator YO'Q bo'lsa computeGenCost statik gen-models.ts qiymatiga qaytadi.
// PUL ZONASIGA TEGMAYDI: cost-quote imzosi hal qilingan yakuniy narxni qamrab oladi
// (signCostQuote/verifyCostQuote O'ZGARMAYDI) — bu model faqat narx MANBAINI ko'chiradi.
model ModelPricing {
  id          String   @id @default(cuid())
  modelId     Int      @unique // GenModel.id (gen-models.ts)
  mode        String   // "image" | "voice" | "video" | "music" | "sfx"
  label       String?
  // ── Kredit narx ta'rifi (computeGenCost SHU qiymatlarni o'qiydi) ──
  cost        Int      // sobit kredit (video: soniya boshiga); fallback baza
  pricing     String?  // video: "per-second" | "per-generation" (null = per-second default)
  qualityCost Json?    // rasm: { "1K": 4, "2K": 8, "4K": 16 } — sifat/resolution → kredit
  videoPerSec Json?    // video: { "720p": 8, "1080p": 8 } — resolution → kredit/soniya
  // ── Marja uchun (best-effort) ──
  estCostUsd  Decimal? @db.Decimal(10, 4) // vakil (default param) real provider USD narxi
  enabled     Boolean  @default(true)
  notes       String?  @db.Text
  updatedBy   String? // oxirgi tahrirlagan admin userId
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([mode])
}

// PricingConfig: global narx sozlamalari (singleton). creditUsdValue = 1 kredit necha $
// (anchor: PRO $19 / 1000 kredit = $0.019). marginTarget = maqsad marja (default 1.8x).
// Admin PATCH bilan o'zgartiradi (kelajak admin UI). Yagona qator id="singleton".
model PricingConfig {
  id             String   @id @default("singleton")
  creditUsdValue Decimal  @default(0.019) @db.Decimal(12, 6)
  marginTarget   Decimal  @default(1.8) @db.Decimal(8, 3)
  updatedBy      String?
  updatedAt      DateTime @updatedAt
}

// ProviderInvoice: admin kiritgan REAL oylik provider hisob-fakturasi (USD). Tizim
// TAXMINI (ProviderSpend.estimatedCostUsd) bilan solishtirish uchun — provider narx
// oshsa real xarajat estimate'dan yuqori chiqadi → drift ko'rinadi (Bosqich 3.5).
model ProviderInvoice {
  id          String   @id @default(cuid())
  provider    String   // "vertex" | "fal" | "elevenlabs" | ...
  periodMonth String   // "YYYY-MM"
  actualUsd   Decimal  @db.Decimal(12, 4)
  note        String?
  createdById String? // admin userId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([provider, periodMonth])
  @@index([periodMonth])
}

// ── Step 20 (D3) — INFRA xarajati: admin kiritgan REAL oylik infratuzilma USD.
// ProviderInvoice naqshi (admin qo'lda kiritadi). Pool BAZASIDAN ayiriladi:
//   pool = max(0, (obuna net − AI xarajati − INFRA)) × poolShare
// Ilgari INFRA ayirilmasdi → contributorga BAND BO'LMAGAN pul to'lanardi (P26 Finding 3).
// EGA QARORI (D3, tasdiqlangan). Money-zone consume/refund/HMAC'ga TEGMAYDI — bu FAQAT
// pool taqsimotining bazasi (payout hali JONLI EMAS). totalUsd = storage+egress+compute.
model InfraCost {
  id          String   @id @default(cuid())
  periodMonth String   @unique // "YYYY-MM"
  storageUsd  Decimal  @default(0) @db.Decimal(12, 4) // GCS ombor
  egressUsd   Decimal  @default(0) @db.Decimal(12, 4) // TRAFIK (egress) — ilgari umuman kuzatilmasdi
  computeUsd  Decimal  @default(0) @db.Decimal(12, 4) // Cloud Run / Neon compute
  note        String?
  createdById String?  // admin userId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([periodMonth])
}

// ── FAZA 4 (A) — REAL daromad hisobi (Lemon Squeezy webhook'dan) ─────────────
// RevenueEvent: har haqiqiy pul hodisasi (obuna to'lovi, kredit-paket, refund,
// chargeback) uchun BITTA qator. Idempotentlik sourceKey @unique bilan
// (createMany+skipDuplicates → webhook retry IKKINCHI qatorni yaratmaydi).
// Manfiy summalar = refund/chargeback. FK-siz (CreditLedger/ProviderSpend naqshi).
// PUL ZONASIGA TEGMAYDI — bu faqat HISOB (accounting), kredit consume/refund emas.
model RevenueEvent {
  id               String   @id @default(cuid())
  sourceKey        String   @unique // rev:order:<id> | rev:invoice:<id> | ...:refund
  userId           String?
  kind             String   // subscription_initial | renewal | credit_pack | refund | chargeback
  plan             String?  // PRO | STUDIO (obuna hodisalari uchun, bilinsa)
  grossCents       Int      // musbat = tushum, manfiy = refund/chargeback
  taxCents         Int      @default(0)
  feeCents         Int      @default(0) // LS webhook fee bermaydi — 0 (kelajak uchun joy)
  netCents         Int      // gross - tax - fee
  currency         String   @default("USD")
  lsOrderId        String?
  lsSubscriptionId String?
  lsInvoiceId      String?
  eventName        String?  // xom LS event nomi (diagnostika)
  occurredAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([kind])
  @@index([occurredAt])
}

// ── FAZA 4 (D) — plan o'zgarishi hodisalari (churn/conversion metrikalari) ───
// Har PluginProfile.plan o'zgarishi uchun BITTA qator (best-effort yozuv —
// plan setter'lar bloklanmaydi). FK-siz (ledger naqshi).
model PlanChangeEvent {
  id        String   @id @default(cuid())
  userId    String
  fromPlan  String
  toPlan    String
  source    String   @default("billing") // billing (LS) | stripe | manual (admin/self)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([toPlan])
}

// ── Bosqich 4 #1 — REAL download/import tracking (zanjir yaxlitligi) ─────────
// TemplateDownloadEvent: HAR haqiqiy pack/mogrt yuklab olish yoki import uchun
// BITTA atomik qatorlangan hodisa (kim, qaysi katalog shabloni, qaysi contributor).
// Contributor statistikasi endi shu REAL hodisalardan olinadi — ilgari forgeable
// ContributorTemplate.downloadsCount/importsCount Int hisoblagichdan olinardi (o'lik
// `Download` model esa hech qachon yaratilmasdi). FK-siz (CreditLedger/ProviderSpend
// naqshi) — mavjud User/ContributorTemplate modellariga tegmaymiz. contributorId
// denormalizatsiya qilingan (payout attribution + tez agregatsiya uchun).
model TemplateDownloadEvent {
  id            String   @id @default(cuid())
  templateId    String
  userId        String
  contributorId String
  kind          String   @default("download") // "download" | "import"
  source        String   @default("plugin")   // "plugin" | "web"
  // ── Step 20 (P26.4 sybil) — ADDITIVE audit izi (clustering uchun). Faqat admin
  // fraud-tahlili o'qiydi; earning/pool matematikasiga TEGMAYDI. null = eski yozuvlar
  // (backfill yo'q) yoki header yetib kelmagan. ipPrefix = tarmoq klasteri kaliti
  // (IPv4 /24, IPv6 /48) — ASN o'rnida proxy (offline GeoIP DB yo'q).
  ip            String?  // xom klient IP (trust proxy → X-Forwarded-For)
  ipPrefix      String?  // IP subnet (/24 yoki /48) — tarmoq yaqinligi klasteri
  userAgent     String?  @db.Text
  asn           String?  // CDN/edge header bergan bo'lsa (cf-connecting-asn va h.k.), aks holda null
  createdAt     DateTime @default(now())

  // FAZA 2 (H1/M7) — earning DEDUP: attribution per (user, template, kind), NOT per
  // scene/slug/repeat. Bir foydalanuvchi bir shablonni qayta yuklab olsa ham BITTA
  // download hodisasi (→ bitta earning). Oylik download LIMITI ALOHIDA (PluginProfile,
  // consumeDownload) — u har yuklab olishda oshaveradi, bu unique unga TEGMAYDI.
  @@unique([userId, templateId, kind])
  @@index([templateId])
  @@index([userId])
  @@index([contributorId])
  @@index([createdAt])
  @@index([templateId, kind])
  @@index([contributorId, ipPrefix]) // Step 20 — contributor bo'yicha tarmoq klasteri
}

// ── FAZA 2 #13 — Tarif limitlari DB'da (admin boshqaradi, backend enforce).
// Seed bugungi konstantalarga teng — xatti-harakat o'zgarmaydi. Narx maydonlari
// FAQAT ko'rsatish uchun; to'lov haqiqati Lemon Squeezy'da (lsVariant* bog'lash).
model PlanConfig {
  plan              PluginPlanTier @id
  label             String
  active            Boolean  @default(true) // Audit §C — admin "Active" toggle endi saqlanadi (hozircha display; enforcement keyin)
  aiMonthlyCredits  Int
  downloadLimit     Int?     // null = cheksiz
  importLimit       Int?     // null = cheksiz
  maxResolution     String   @default("1080p")
  priceMonthlyCents Int?     // display-only
  priceYearlyCents  Int?     // display-only
  lsVariantMonthly  String?  // Lemon Squeezy variant id (admin bog'laydi)
  lsVariantYearly   String?
  updatedAt         DateTime @updatedAt
}

// ── FAZA 2 (H7) — /gen kunlik cap DB'da (in-memory Map o'rniga). Process restart /
// multi-instance holatida in-memory hisoblagich nolga qaytib cap'ni chetlab o'tardi.
// day = UTC kun raqami (Date.now()/86_400_000). kind = "gen" | "helper". Har kuni yangi qator.
model DailyUsageCounter {
  userId    String
  day       Int
  kind      String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@id([userId, day, kind])
  @@index([day])
}

// ── FAZA 2 #17 — Sevimlilar (plagin↔web umumiy). FK-siz (TemplateDownloadEvent
// naqshi) — shablon o'chsa yetim qator zararsiz (katalogga filtr bilan ko'rinmaydi).
model UserTemplateFavorite {
  id         String   @id @default(cuid())
  userId     String
  templateId String
  createdAt  DateTime @default(now())

  @@unique([userId, templateId])
  @@index([userId])
}

// ── Bosqich 4 #3 — Contributor payout / earnings (50% ulush) ────────────────
// Shablonlar obunaga kiritilgan (cheksiz yuklab olish) → per-sotuv attribution
// to'g'ridan qo'llanmaydi. Shu bois DEFAULT (sozlanadigan) formula: HAR download
// hodisasi uchun qat'iy stavka (CONTRIBUTOR_PAYOUT_PER_DOWNLOAD_CENTS, default 10¢).
// ⚠️ EGA QARORI: aniq stavka/formula (qat'iy-per-download vs oylik pool ulushi) va
// "50% ulush"ni maqsadga moslashtirish — biznes qarori (kod default beradi, qulflamaydi).
//
// ContributorEarning: har download hodisasi uchun BITTA earning qatori. Idempotentlik
// downloadEventId @unique bilan (bir hodisa IKKI marta kredit BERMAYDI). Grant ADDITIVE
// va HECH QACHON manfiy emas (amountCents > 0 gate). FK-siz (ledger naqshi).
model ContributorEarning {
  id              String   @id @default(cuid())
  contributorId   String
  templateId      String
  downloadEventId String   @unique // idempotency key — bir download = bir earning
  amountCents     Int                 // >= 0, additive, hech qachon manfiy emas
  currency        String   @default("USD")
  payoutId        String?             // admin payout'ga kiritilganda o'rnatiladi
  // FAZA 4 (C) — pool payout: kind="download" (per-download yoki pool-rejim MARKER,
  // pool rejimida amount=0) | kind="pool" (davr taqsimoti qatori,
  // downloadEventId="pool:<YYYY-MM>:<contributorId>" → davr+contributor idempotent).
  kind            String   @default("download")
  periodMonth     String?             // pool qatorlari uchun "YYYY-MM"
  createdAt       DateTime @default(now())

  @@index([contributorId])
  @@index([payoutId])
  @@index([templateId])
  @@index([createdAt])
  @@index([kind, periodMonth])
}

// ContributorPayout: admin tomonidan yozilgan to'lov qaydi (Khamkorbank UZ va h.k.).
// To'lov earning qatorlari amountlarini O'ZGARTIRMAYDI — faqat ularni payoutId bilan
// bog'laydi (balans = to'lanmagan earninglar yig'indisi).
model ContributorPayout {
  id            String    @id @default(cuid())
  contributorId String
  amountCents   Int
  currency      String    @default("USD")
  method        String?               // "khamkorbank" | "manual" | ...
  reference     String?               // bank ref / izoh
  note          String?
  status        String    @default("paid") // "pending" | "paid" | "reversed"
  periodStart   DateTime?
  periodEnd     DateTime?
  createdById   String?               // admin userId
  createdAt     DateTime  @default(now())

  @@index([contributorId])
  @@index([status])
  @@index([createdAt])
}

// ── FAZA 1d — DMCA / infringement report (public wrapper on existing takedown) ──
// Ommaviy "Report infringement" formasi shu qatorni yaratadi (pending). Admin ko'rib,
// tasdiqlangan da'voni MAVJUD takedown endpoint'i (contributor.ts) orqali amalga oshiradi;
// bu model faqat da'vo-hujjatini saqlaydi (FK-siz — template o'chsa yetim qator zararsiz).
// ⚠️ needs lawyer review — designated agent, notice/counter-notice tartibi. docs/LEGAL-TODO.md.
model InfringementReport {
  id             String    @id @default(cuid())
  templateId     String?              // da'vo qilingan shablon (ixtiyoriy — erkin matn ham bo'lishi mumkin)
  reporterName   String?
  reporterEmail  String
  claimantType   String?              // "owner" | "authorized_agent"
  workDescription String   @db.Text   // egalik qilinadigan asar / huquq tavsifi
  infringingUrl  String?              // da'vo qilingan joy (URL/ID)
  goodFaith      Boolean   @default(false) // "good faith" tasdig'i
  status         String    @default("pending") // pending | actioned | dismissed
  resolutionNote String?
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([status])
  @@index([templateId])
  @@index([createdAt])
}

// ── Landing CMS (admin "Website" tab) — bitta qator (id=1), butun landing
// konfiguratsiyasi JSON blob'da. Default qiymatlar KODDA (apps/api landing-config.ts):
// qator yo'q/bo'sh bo'lsa landing hozirgi hardcoded kontent bilan bir xil ko'rinadi.
model LandingConfig {
  id          Int      @id @default(1)
  data        Json     @default("{}")
  updatedById String?
  updatedAt   DateTime @updatedAt
}

// ── P11 — Plagin relizlari (in-panel update kanali). ADDITIVE: mavjud modellarga
// tegilmaydi. downloadKey = storage'dagi paket (releases/<v>.zip); mandatory yoki
// minSupportedVersion ostidagi klient bloklanadi (update majburiy).
model PluginRelease {
  id                  String   @id @default(cuid())
  version             String   @unique // semver: "1.2.0"
  downloadKey         String   // storage kaliti (releases/...)
  releaseNotes        String?  @db.Text
  mandatory           Boolean  @default(false)
  minSupportedVersion String?  // bundan past klientlar bloklanadi
  checksum            String?  // sha256 (ixtiyoriy, updater tekshiradi)
  publishedAt         DateTime @default(now())
  createdById         String?

  @@index([publishedAt])
}

// ── P1 #19 (P6 §4 / P7 §8) — QAYTA TIKLANADIGAN BULK-INGEST NAVBATI ──────────
// Ingest endi HTTP so'rov yo'lida EMAS: POST /ingest incoming kalitlarni shu
// navbatga QO'SHADI va darhol qaytadi; alohida fon ishchisi (ingest-worker.ts,
// o'zining Cloud Run job'i yoki inline poller) elementlarni birma-bir claim qilib
// ishlaydi. 5000 klip ≈ 42–83 soat ffmpeg — bu foydalanuvchi trafigi bilan CPU
// uchun raqobatlashmasligi kerak. Har element uchun retry (attempts/maxAttempts),
// progress (status), restartdan keyin davom etish (claimedAt eskirsa → queued).
//
// FK-siz (ledger/download-event naqshi): shablon/contributor o'chsa yetim job
// zararsiz (worker key topilmasa "failed" qiladi). sourceType='zip' → ingestOneZip
// (Video Templates), 'asset' → ingestOneAsset (raw LUTs/Stock — P1.9).
model IngestJob {
  id            String   @id @default(cuid())
  batchId       String   // bitta upload seansi — progress polling grouping
  contributorId String
  sourceType    String   // 'zip' | 'asset'
  key           String   // incoming/<contributorId>/<file> storage kaliti
  fileName      String   // asl fayl nomi (UI/log uchun)
  // Taksonomiya — raw asset ingest'i uchun (zip'da AI/zip-parse aniqlaydi, null qoladi).
  kind          String?  // 'template' | 'stock'
  templateType  String?  // 'video-templates' | 'luts'
  stockType     String?  // 'graphics'|'motion-graphics'|'music'|'sfx'
  templateApp   String?  // ae|pr|motion|resolve (video-templates uchun)
  contentType   String?  // asl fayl MIME (raw asset uchun)
  // Rights attestation (butun partiyaga bir marta — server-side MAJBURIY, contributor.ts).
  rightsAcceptedAt   DateTime?
  rightsTermsVersion String?
  status        String   @default("queued") // queued|processing|done|duplicate|failed
  attempts      Int      @default(0)
  maxAttempts   Int      @default(3)
  lastError     String?
  resultTemplateId String? // done bo'lsa yaratilgan shablon id'si (duplicate = mavjud id)
  claimedAt     DateTime?   // processing'ga o'tgan payt (stuck-reclaim uchun)
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, createdAt])
  @@index([batchId])
  @@index([contributorId, createdAt])
}
