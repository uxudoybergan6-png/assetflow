generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  CONTRIBUTOR
}

enum TemplateReviewStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
}

enum AssetType {
  MOTION_TEMPLATE
  TRANSITION
  VFX_OVERLAY
  TEXTURE
  LUT
  PRESET
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  passwordHash     String?
  role                 UserRole  @default(USER)
  contributorBlockedAt DateTime?
  stripeCustomerId     String?   @unique
  emailVerified    DateTime?
  image            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  subscription  Subscription?
  downloads     Download[]
  pluginTokens          PluginToken[]
  pluginProfile         PluginProfile?
  contributorTemplates  ContributorTemplate[] @relation("ContributorTemplates")
  reviewedTemplates     ContributorTemplate[] @relation("ReviewedTemplates")
  studioThreads         StudioMessageThread[] @relation("ContributorThreads")
  studioMessagesSent    StudioMessage[]       @relation("StudioMessagesSent")
  studioAuditLogs       StudioAuditLog[]      @relation("StudioAuditActor")
  aiGenerations         AiGeneration[]
  genSessions           GenSession[]
  generations           Generation[]

  @@index([role])
}

enum PluginPlanTier {
  FREE
  PRO
}

enum PluginAccountStatus {
  ACTIVE
  BLOCKED
  REMOVED
}

model PluginProfile {
  userId         String               @id
  plan           PluginPlanTier       @default(FREE)
  status         PluginAccountStatus  @default(ACTIVE)
  downloadsTotal Int                  @default(0)
  downloadsMonth Int                  @default(0)
  importsTotal   Int                  @default(0)
  monthResetAt   DateTime             @default(now())
  aiCredits      Int                  @default(50)
  aiCreditsResetAt DateTime           @default(now())
  lastSeenAt     DateTime?
  deviceLabel    String?
  aeVersion      String?
  downloadLimitOverride Int?
  importLimitOverride   Int?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([plan])
  @@index([lastSeenAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Stripe webhook idempotency — har event.id bir marta ishlanadi
/// (takror/parallel yetkazishni dedup qiladi).
model WebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

model Asset {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String?
  type        AssetType
  category    String
  tags        String[]
  fileKey     String
  thumbnailKey String?
  fileSize    Int
  duration    Float?
  width       Int?
  height      Int?
  published   Boolean   @default(false)
  downloadCount Int     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  downloads Download[]

  @@index([type, category])
  @@index([published])
}

model Download {
  id        String   @id @default(cuid())
  userId    String
  assetId   String
  source    String   @default("web")
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assetId])
}

model PluginToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model ContributorPlatformSettings {
  id                      String   @id @default("platform")
  apiBaseUrl              String?
  requireApproval         Boolean  @default(true)
  defaultNav              String   @default("video")
  defaultRes              String   @default("4k")
  defaultOrient           String   @default("horizontal")
  categoriesJson          Json     @default("[]")
  contributorInstructions String?  @db.Text
  updatedAt               DateTime @updatedAt
}

model ContributorTemplate {
  id            String               @id @default(cuid())
  contributorId String
  externalId    String?
  name          String
  description   String               @default("")
  nav           String               @default("video")
  cat           String
  catLabel      String
  orient        String               @default("horizontal")
  res           String               @default("4k")
  tags          String[]
  icon          String               @default("✦")
  bg            String               @default("")
  templateApp   String               @default("ae")
  metaJson      Json                 @default("{}")
  fileName      String?
  fileSize      Int?
  reviewStatus  TemplateReviewStatus @default(DRAFT)
  reviewNote    String?
  reviewedById  String?
  reviewedAt    DateTime?
  published     Boolean              @default(false)
  downloadsCount Int                 @default(0)
  importsCount   Int                 @default(0)
  embedding     Json?                // Semantik qidiruv uchun embedding vektori (bge-m3, JSON float[])
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  contributor User  @relation("ContributorTemplates", fields: [contributorId], references: [id], onDelete: Cascade)
  reviewer    User? @relation("ReviewedTemplates", fields: [reviewedById], references: [id])
  messageThreads StudioMessageThread[]

  @@unique([contributorId, externalId])
  @@index([contributorId])
  @@index([reviewStatus])
  @@index([published])
  @@index([reviewStatus, published, updatedAt])
}

model StudioMessageThread {
  id            String   @id @default(cuid())
  contributorId String
  templateId    String?
  subject       String
  isBroadcast   Boolean  @default(false)
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contributor User                 @relation("ContributorThreads", fields: [contributorId], references: [id], onDelete: Cascade)
  template    ContributorTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  messages    StudioMessage[]

  @@index([contributorId])
  @@index([lastMessageAt])
  @@index([templateId])
}

model StudioMessage {
  id        String    @id @default(cuid())
  threadId  String
  senderId  String
  body      String    @db.Text
  readAt    DateTime?
  createdAt DateTime  @default(now())

  thread StudioMessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User                @relation("StudioMessagesSent", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([senderId])
}

model StudioAuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  detail     String?  @db.Text
  metaJson   Json     @default("{}")
  createdAt  DateTime @default(now())

  actor User? @relation("StudioAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([createdAt])
  @@index([actorId])
}

enum AiGenerationType {
  IMAGE
  VOICEOVER
  SFX
  SEARCH
}

enum AiGenerationStatus {
  PENDING
  DONE
  FAILED
}

model AiGeneration {
  id        String             @id @default(cuid())
  userId    String
  type      AiGenerationType
  prompt    String             @db.Text
  resultKey String?
  credits   Int                @default(0)
  status    AiGenerationStatus @default(PENDING)
  createdAt DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ── Studio Gen (Artlist uslubi) — session = ish maydoni ─────────────────────
// AiGeneration (yuqorida) eski sinxron AI Tools oqimi uchun qoladi; yangi generativ
// studio oqimi GenSession/Generation/GenAsset bilan ishlaydi (job + tarix + signed quote).

model GenSession {
  id          String       @id @default(cuid())
  userId      String
  title       String?
  mode        String       @default("image") // image | voice | video | music
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  generations Generation[]

  @@index([userId])
  @@index([createdAt])
}

model Generation {
  id        String     @id @default(cuid()) // jobId sifatida ishlatiladi
  sessionId String
  userId    String                          // kredit/egalik va tezkor so'rov uchun
  mode      String                          // image | voice | video | music
  prompt    String     @db.Text
  modelId   Int                             // model katalog ID (Artlist uslubi → Workers AI key'ga map)
  params    Json       @default("{}")       // duration/aspectRatio/referenceKey...
  status    String     @default("queued")   // queued | running | done | failed
  category  String?
  cost      Int        @default(0)
  error     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  session   GenSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets    GenAsset[]

  @@index([sessionId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model GenAsset {
  id           String     @id @default(cuid())
  generationId String
  type         Int                          // 140=video kabi tur kodi (Artlist uslubi)
  url          String                       // R2/CDN URL (signed yoki public)
  resultKey    String?                      // R2 obyekt kaliti (signed URL qayta yaratish uchun)
  thumbUrl     String?
  width        Int?
  height       Int?
  aspectRatio  String?                      // "16:9"
  createdAt    DateTime   @default(now())

  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@index([generationId])
}
