{
  "buildCommand": "node scripts/prepare-vercel.mjs",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/studio/login.html", "destination": "/studio/login.html" },
    { "source": "/studio/contributor", "destination": "/studio/contributor/index.html" },
    { "source": "/studio/contributor/", "destination": "/studio/contributor/index.html" },
    { "source": "/contributor", "destination": "/studio/contributor/index.html" },
    { "source": "/contributor/", "destination": "/studio/contributor/index.html" },
