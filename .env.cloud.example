# ── PostgreSQL (Neon.tech) ─────────────────────────────────────────────────
# https://neon.tech → New Project → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── API ───────────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=10000
# MAJBURIY: productionda default qiymat bilan server ishga tushmaydi.
# Generatsiya: openssl rand -hex 32
JWT_SECRET="generate-random-64-char-string"
# Cost-quote imzosi uchun ALOHIDA kalit (auth JWT_SECRET'dan farqli — Bosqich 1 #4).
# Yo'q bo'lsa JWT_SECRET'ga qaytadi (buzilmaydi), lekin productionда ALOHIDA qiymat SHART.
# Generatsiya: openssl rand -hex 32
COST_QUOTE_SECRET="generate-a-DIFFERENT-random-64-char-string"
# FAIL-CLOSED: productionда DOIM false — PRO faqat Stripe ACTIVE obuna orqali beriladi.
# =true FAQAT lokal dev uchun (Stripe'siz PRO'ni sinash). Productionда =true = tekin PRO teshigi.
PLUGIN_ALLOW_PRO_WITHOUT_STRIPE=false

# ── Spend himoyasi (Bosqich 1 #2) ─────────────────────────────────────────
# Favqulodda "tормоз": =true qilinsa barcha yangi AI generatsiya 503 (charge yo'q).
GEN_KILL_SWITCH=false
# Bitta hisob kuniga nechta /gen qila oladi (ADMIN ozod). Bo'sh → 200.
GEN_DAILY_CAP=200
# Global provider USD shifti (ProviderSpend.estimatedCostUsd yig'indisi). Bo'sh → o'chirilgan.
# Oshsa /gen 503 (charge yo'q) — runaway bill'dan himoya.
GEN_DAILY_USD_CEILING=
GEN_MONTHLY_USD_CEILING=

# ── Monitoring (Sentry — Bosqich 1 #6) ────────────────────────────────────
# https://sentry.io → Project → DSN. Bo'sh → monitoring o'chirilgan (no-op).
# Faollashtirish: `npm i @sentry/node -w apps/api` + shu DSN.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# ── Email (Resend) — parol tiklash + moderatsiya bildirishnomalari ─────────
# https://resend.com → API Keys. Bo'lmasa email yuborilmaydi (havola log'ga yoziladi).
RESEND_API_KEY="re_xxx"
EMAIL_FROM="AssetFlow <no-reply@sizning-domeningiz.uz>"

# ── Stripe (Pro obuna) ─────────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API keys / Webhooks / Products
STRIPE_SECRET_KEY="sk_live_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
STRIPE_PRICE_MONTHLY="price_xxx"
STRIPE_PRICE_YEARLY="price_xxx"

# ── CORS (frontend URL'lar) ───────────────────────────────────────────────
API_PUBLIC_URL="https://assetflow-rqbq.onrender.com"
CORS_ORIGIN="https://assetflow-20j.pages.dev"
ADMIN_URL="https://assetflow-20j.pages.dev/admin/"
WEB_URL="https://assetflow-20j.pages.dev"

# ── Cloudflare R2 (fayl saqlash) ─────────────────────────────────────────
# https://dash.cloudflare.com → R2 → Create bucket
# API Token: R2:Edit permission
AWS_ACCESS_KEY_ID="r2-access-key-id"
AWS_SECRET_ACCESS_KEY="r2-secret-access-key"
AWS_S3_BUCKET="assetflow-uploads"
AWS_REGION=auto
S3_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
CDN_BASE_URL="https://pub-HASH.r2.dev"   # R2 Public bucket URL
